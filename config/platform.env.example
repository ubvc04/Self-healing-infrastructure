# Copy this file to config/platform.env and update values.
GIT_ORG=your-github-org
GIT_REPO=self-healing-k8s-platform
GIT_BRANCH=main

# Registry base used in manifests, without trailing slash.
IMAGE_REGISTRY=ghcr.io/your-github-org

# Public ingress host for API.
API_HOST=api.platform.example.com

# RabbitMQ app credentials for demo workload.
RABBITMQ_USERNAME=appuser
RABBITMQ_PASSWORD=change-me-strong-password

# SSH key path used by bootstrap script.
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519

# Optional: restrict SSH from terraform vars if desired.
SSH_INGRESS_CIDR=0.0.0.0/0
